# 阿里云百炼 DashScope API Key（必填）
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# OpenAI API Key（可选，使用GPT模型时需要）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 和风天气 API Key（可选，用于天气查询工具）
# 免费申请: https://dev.qweather.com/
QWEATHER_API_KEY=

# 默认城市（天气查询使用）
DEFAULT_CITY=北京

# 操作者标识
OPERATOR_NAME=admin

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
